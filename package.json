{
  "name": "wangchao",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo run build",
    "db:wait": "node scripts/wait-for-database.mjs",
    "db:deploy": "pnpm --filter @wangchao/db exec prisma migrate deploy --schema prisma/schema.prisma",
    "db:format": "pnpm --filter @wangchao/db db:format",
    "db:generate": "pnpm --filter @wangchao/db db:generate",
    "db:migrate": "pnpm --filter @wangchao/db db:migrate",
    "db:seed": "pnpm --filter @wangchao/db db:seed",
    "db:validate": "pnpm --filter @wangchao/db db:validate",
    "dev": "turbo run dev --parallel",
    "railway:web:build": "pnpm db:generate && pnpm --filter @wangchao/web build",
    "railway:web:start": "pnpm --filter @wangchao/web start",
    "railway:build": "pnpm db:generate && pnpm build",
    "railway:build:web": "pnpm db:generate && turbo run build --filter=@wangchao/web",
    "railway:build:worker": "pnpm db:generate && turbo run build --filter=@wangchao/worker",
    "railway:predeploy": "if [ \"$WANGCHAO_RAILWAY_ROLE\" = \"web\" ]; then pnpm railway:web:predeploy; else echo \"Skipping predeploy for $WANGCHAO_RAILWAY_ROLE\"; fi",
    "railway:web:predeploy": "pnpm --filter @wangchao/web validate:deployment && pnpm db:wait && pnpm db:deploy && if [ \"${WANGCHAO_DEPLOYMENT_MODE:-self-hosted}\" = \"commercial\" ]; then echo \"Skipping default workspace seed in commercial mode\"; else pnpm db:seed; fi",
    "railway:start": "if [ \"$WANGCHAO_RAILWAY_ROLE\" = \"queue-worker\" ]; then pnpm railway:queue-worker:start; elif [ \"$WANGCHAO_RAILWAY_ROLE\" = \"worker\" ]; then pnpm railway:worker:start; else pnpm railway:web:start; fi",
    "railway:worker:build": "pnpm db:generate && pnpm --filter @wangchao/worker build",
    "railway:worker:predeploy": "pnpm db:wait && pnpm db:deploy",
    "railway:worker:start": "pnpm --filter @wangchao/worker start",
    "railway:queue-worker:start": "pnpm --filter @wangchao/worker queue-worker",
    "smoke:web": "playwright test",
    "worker:source-discovery": "pnpm --filter @wangchao/worker source-discovery",
    "worker:task-runs": "pnpm --filter @wangchao/worker task-runs",
    "worker:health": "pnpm --filter @wangchao/worker health",
    "worker:instant-push": "pnpm --filter @wangchao/worker instant-push",
    "worker:report-generation": "pnpm --filter @wangchao/worker report-generation",
    "worker:queue": "pnpm --filter @wangchao/worker queue-worker",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3"
  }
}
