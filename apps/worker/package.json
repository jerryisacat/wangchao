{
  "name": "@wangchao/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "health": "node dist/index.js --health",
    "instant-push": "node dist/index.js --instant-push",
    "report-generation": "node dist/index.js --report-generation",
    "lint": "tsc -p tsconfig.json --noEmit",
    "source-discovery": "node dist/index.js --source-discovery",
    "task-runs": "node dist/index.js --task-runs",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.json && node -e \"await import('./dist/index.fixtures.js').then((m) => m.runWorkerFixtures())\"",
    "test:organization-pg": "tsc -p tsconfig.json && node -e \"await import('./dist/modules/organization-cycle-pg.fixtures.js').then((m) => m.runOrganizationCyclePgFixtures())\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wangchao/ai": "workspace:*",
    "@wangchao/core": "workspace:*",
    "@wangchao/db": "workspace:*",
    "@wangchao/sources": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
