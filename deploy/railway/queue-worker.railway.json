{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm railway:build"
  },
  "deploy": {
    "preDeployCommand": "pnpm railway:worker:predeploy",
    "startCommand": "pnpm railway:queue-worker:start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": "0",
    "drainingSeconds": "15"
  }
}
