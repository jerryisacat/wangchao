{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm railway:build"
  },
  "deploy": {
    "preDeployCommand": "pnpm railway:worker:predeploy",
    "startCommand": "pnpm worker:report-generation",
    "cronSchedule": "*/10 * * * *",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 1
  }
}
