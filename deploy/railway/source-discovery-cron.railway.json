{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm railway:build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @wangchao/worker source-discovery",
    "cronSchedule": "0 2 * * 1",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 1
  }
}
