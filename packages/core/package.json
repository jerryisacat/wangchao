{
  "name": "@wangchao/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./dist/render-pdf.js": {
      "types": "./src/render-pdf.ts",
      "default": "./dist/render-pdf.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
