generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserAccountStatus {
  ACTIVE
  SUSPENDED
  DELETION_PENDING
  DELETED
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum TopicStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SourceKind {
  RSS
  WEB
}

enum SourceStatus {
  CANDIDATE
  ACTIVE
  MUTED
  REJECTED
}

enum ItemStatus {
  FETCHED
  FILTERED
  ANALYZED
  DUPLICATE
  ERROR
}

enum ItemContentStatus {
  PENDING
  READY
  INSUFFICIENT
  FETCH_FAILED
  UNSUPPORTED
}

enum ItemContentSource {
  RSS_EMBEDDED
  ARTICLE_HTML
  LEGACY_TEXT
}

enum EventSummaryStatus {
  PENDING
  READY
  CONTENT_FETCH_FAILED
  CONTENT_INSUFFICIENT
  CONTENT_UNSUPPORTED
  AI_FAILED
}

enum EventStatus {
  UNREAD
  READ
  SAVED
  DISMISSED
  ARCHIVED
}

enum FeedbackKind {
  READ
  SAVE
  DISMISS
  EXPORT
  SOURCE_APPROVE
  SOURCE_REJECT
  SOURCE_QUALITY_UP
  SOURCE_QUALITY_DOWN
  SCORE_UP
  SCORE_DOWN
  CATEGORY_UP
  CATEGORY_DOWN
  MORE_LIKE_THIS
  LESS_LIKE_THIS
}

enum BriefingPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum ExportFormat {
  MARKDOWN
  PDF
  JSON
}

enum TaskRunType {
  SOURCE_FETCH
  CONTENT_FETCH
  SOURCE_DISCOVERY
  AI_RELEVANCE
  AI_EVENT_EXTRACTION
  BRIEFING_GENERATION
  EXPORT_GENERATION
  REPORT_GENERATION
  TELEGRAM_DELIVERY
  TELEGRAM_INSTANT_PUSH
}

enum TaskRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum UsageEventType {
  AI_CALL
  FETCH
  EXPORT
  BRIEFING
  SOURCE_GOVERNANCE
  SOURCE_DISCOVERY
  WEB_ACTION
  INSTANT_PUSH
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  name                String
  emailVerified       Boolean            @default(false)
  image               String?
  accountStatus       UserAccountStatus  @default(ACTIVE)
  suspendedAt         DateTime?
  suspendedReason     String?
  suspendEndsAt       DateTime?
  deletionRequestedAt DateTime?
  deletedAt           DateTime?
  lastLoginAt         DateTime?
  lastActivityAt      DateTime?
  memberships         Membership[]
  topics              Topic[]
  itemStates          UserItemState[]
  feedbackEvents      FeedbackEvent[]
  preferenceMemory    PreferenceMemory[]
  exportEvents        ExportEvent[]
  usageEvents         UsageEvent[]
  accounts            Account[]
  sessions            Session[]
  platformAdmin       PlatformAdmin?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([accountStatus])
}

model Organization {
  id                 String                   @id @default(cuid())
  name               String
  slug               String                   @unique
  memberships        Membership[]
  topics             Topic[]
  sources            Source[]
  items              Item[]
  intelligenceEvents IntelligenceEvent[]
  feedbackEvents     FeedbackEvent[]
  preferenceMemory   PreferenceMemory[]
  briefings          Briefing[]
  exportEvents       ExportEvent[]
  sourceObservations SourceObservation[]
  taskRuns           TaskRun[]
  usageEvents        UsageEvent[]
  deliveryLogs       DeliveryLog[]
  reports            Report[]
  paymentInvoices    PaymentInvoice[]
  webhookEvents      WebhookEvent[]
  subscription       Subscription[]
  credentials        OrganizationCredential[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  instantPushLogs    InstantPushLog[]
}

enum Plan {
  FREE
  PLUS
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum CredentialType {
  AI
  SEARCH
  BYOK
  TELEGRAM
  CCPAYMENT
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum DeliveryChannel {
  TELEGRAM
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum InstantPushStatus {
  PENDING
  SENDING
  SENT
  FAILED
  SKIPPED
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
  INSUFFICIENT_DATA
}

model Subscription {
  id             String @id @default(cuid())
  organizationId String @unique

  plan               Plan               @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  billingInterval    BillingInterval    @default(MONTHLY)
  isSelfHosted       Boolean            @default(false)
  showAdsInSelfHosted Boolean           @default(true)

  stripeCustomerId     String?
  stripeSubscriptionId String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  metadata           Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model OrganizationCredential {
  id             String         @id @default(cuid())
  organizationId String
  credentialType CredentialType

  encryptedKey    String?
  encryptedSecret String?
  keyHint         String?

  baseUrl  String?
  provider String?
  model    String?

  appId  String?
  chatId String?

  enabled              Boolean   @default(false)
  instantPushEnabled   Boolean   @default(false)
  instantPushEnabledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, credentialType])
  @@index([organizationId])
  @@index([credentialType])
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(MEMBER)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
}

model Topic {
  id                 String              @id @default(cuid())
  organizationId     String
  ownerUserId        String?
  name               String
  description        String?
  profile            Json?
  status             TopicStatus         @default(ACTIVE)
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerUser          User?               @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  sources            Source[]
  items              Item[]
  intelligenceEvents IntelligenceEvent[]
  feedbackEvents     FeedbackEvent[]
  preferenceMemory   PreferenceMemory[]
  briefings          Briefing[]
  exportEvents       ExportEvent[]
  sourceObservations SourceObservation[]
  taskRuns           TaskRun[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, status])
  @@index([ownerUserId])
}

model Source {
  id                   String              @id @default(cuid())
  organizationId       String
  topicId              String
  kind                 SourceKind          @default(RSS)
  status               SourceStatus        @default(CANDIDATE)
  name                 String
  url                  String
  canonicalUrl         String
  description          String?
  recommendationReason String?
  discoveryChannel     String?
  trustScore           Float               @default(0)
  qualityScore         Float               @default(0)
  lastFetchedAt        DateTime?
  lastError            String?
  lastErrorAt          DateTime?
  consecutiveFailures  Int                 @default(0)
  observeExpiresAt     DateTime?
  organization         Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topic                Topic               @relation(fields: [topicId], references: [id], onDelete: Cascade)
  items                Item[]
  feedbackEvents       FeedbackEvent[]
  sourceObservations   SourceObservation[]
  taskRuns             TaskRun[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@unique([topicId, canonicalUrl])
  @@index([organizationId, status])
  @@index([topicId, status])
}

model Item {
  id                 String              @id @default(cuid())
  organizationId     String
  topicId            String
  sourceId           String
  status             ItemStatus          @default(FETCHED)
  title              String
  url                String
  canonicalUrl       String
  summary            String?
  author             String?
  publishedAt        DateTime?
  fetchedAt          DateTime            @default(now())
  contentHash        String?
  rawContent         String?
  contentStatus      ItemContentStatus   @default(PENDING)
  contentSource      ItemContentSource?
  contentFetchedAt   DateTime?
  contentErrorCode   String?
  rawMetadata        Json?
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topic              Topic               @relation(fields: [topicId], references: [id], onDelete: Cascade)
  source             Source              @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  intelligenceEvents IntelligenceEvent[] @relation("PrimaryItem")
  eventItems         EventItem[]
  feedbackEvents     FeedbackEvent[]
  taskRuns           TaskRun[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([topicId, canonicalUrl])
  @@index([organizationId, status])
  @@index([organizationId, contentStatus])
  @@index([topicId, status, publishedAt])
  @@index([sourceId, fetchedAt])
  @@index([contentHash])
}

model IntelligenceEvent {
  id                 String             @id @default(cuid())
  organizationId     String
  topicId            String
  primaryItemId      String?
  status             EventStatus        @default(UNREAD)
  title              String
  summary            String
  summaryStatus      EventSummaryStatus @default(READY)
  summaryRequestedAt DateTime?
  category           String?
  score              Float              @default(0)
  gravityScore       Float              @default(0)
  eventHash          String?
  titleHash          String?
  explanation        String?
  entities           String[]           @default([])
  followUpSuggestion String?
  mergeReason        String?
  occurredAt         DateTime?
  rawAiResponse      Json?
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topic              Topic              @relation(fields: [topicId], references: [id], onDelete: Cascade)
  primaryItem        Item?              @relation("PrimaryItem", fields: [primaryItemId], references: [id], onDelete: SetNull)
  eventItems         EventItem[]
  userStates         UserItemState[]
  feedbackEvents     FeedbackEvent[]
  briefings          Briefing[]         @relation("BriefingEvents")
  exportEvents       ExportEvent[]
  taskRuns           TaskRun[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  instantPushLogs    InstantPushLog[]

  @@unique([topicId, eventHash])
  @@index([organizationId, status])
  @@index([topicId, status, gravityScore])
  @@index([primaryItemId])
  @@index([topicId, titleHash, occurredAt])
}

model EventItem {
  id          String   @id @default(cuid())
  eventId     String
  itemId      String
  role        String   @default("SECONDARY")
  mergedAt    DateTime @default(now())
  mergeReason String?

  event IntelligenceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  item  Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([eventId, itemId])
  @@index([eventId])
  @@index([itemId])
}

model UserItemState {
  id        String            @id @default(cuid())
  userId    String
  eventId   String
  status    EventStatus       @default(UNREAD)
  saved     Boolean           @default(false)
  readAt    DateTime?
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     IntelligenceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId, status])
}

model FeedbackEvent {
  id             String             @id @default(cuid())
  organizationId String
  topicId        String
  userId         String?
  eventId        String?
  itemId         String?
  sourceId       String?
  kind           FeedbackKind
  value          Int?
  reason         String?
  metadata       Json?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topic          Topic              @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  event          IntelligenceEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  item           Item?              @relation(fields: [itemId], references: [id], onDelete: SetNull)
  source         Source?            @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())

  @@index([organizationId, kind, createdAt])
  @@index([topicId, kind, createdAt])
  @@index([userId])
  @@index([eventId])
  @@index([sourceId])
}

model PreferenceMemory {
  id             String       @id @default(cuid())
  organizationId String
  topicId        String
  userId         String?
  key            String
  value          Json
  explanation    String
  confidence     Float        @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topic          Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([topicId, userId, key])
  @@index([organizationId, topicId])
}

model Briefing {
  id             String              @id @default(cuid())
  organizationId String
  topicId        String
  period         BriefingPeriod      @default(DAILY)
  title          String
  content        String
  markdown       String?
  generatedAt    DateTime            @default(now())
  rangeStart     DateTime
  rangeEnd       DateTime
  metadata       Json?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topic          Topic               @relation(fields: [topicId], references: [id], onDelete: Cascade)
  events         IntelligenceEvent[] @relation("BriefingEvents")
  exportEvents   ExportEvent[]
  deliveryLogs   DeliveryLog[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([topicId, period, rangeStart])
  @@index([organizationId, generatedAt])
  @@index([topicId, period, generatedAt])
}

model ExportEvent {
  id             String             @id @default(cuid())
  organizationId String
  topicId        String
  userId         String?
  eventId        String?
  briefingId     String?
  format         ExportFormat       @default(MARKDOWN)
  fileName       String?
  contentHash    String?
  metadata       Json?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topic          Topic              @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  event          IntelligenceEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  briefing       Briefing?          @relation(fields: [briefingId], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())

  @@index([organizationId, createdAt])
  @@index([topicId, format])
  @@index([userId])
}

model SourceObservation {
  id             String       @id @default(cuid())
  organizationId String
  topicId        String
  sourceId       String?
  candidateUrl   String?
  hitRate        Float        @default(0)
  noiseRate      Float        @default(0)
  duplicateRate  Float        @default(0)
  evidence       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topic          Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  source         Source?      @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  observedAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@index([organizationId, observedAt])
  @@index([topicId, observedAt])
  @@index([sourceId])
}

model TaskRun {
  id             String        @id @default(cuid())
  organizationId String
  topicId        String?
  sourceId       String?
  itemId         String?
  eventId        String?
  type           TaskRunType
  status         TaskRunStatus @default(PENDING)
  attempt        Int           @default(0)
  maxAttempts    Int           @default(3)
  scheduledAt    DateTime      @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  errorMessage   String?
  input          Json?
  output         Json? // Truncated at 100KB before persistence to prevent row size overflow.

  // Issue #162 Lane 1A — lease/idempotency contract.
  // All five fields are nullable: absent on PENDING rows that have not yet been
  // claimed, and cleared on terminal rows so the same business key can be reused.
  // The partial unique active-idempotency constraint is migration-owned (see
  // migration 0017) because Prisma cannot express WHERE-filtered @@unique.
  idempotencyKey String?
  leaseOwner     String?
  leaseToken     String?
  leaseExpiresAt DateTime?
  heartbeatAt    DateTime?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topic        Topic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  source       Source?            @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  item         Item?              @relation(fields: [itemId], references: [id], onDelete: SetNull)
  event        IntelligenceEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([organizationId, status, scheduledAt])
  @@index([topicId, type])
  @@index([sourceId, status])
  // Due scan for the worker claim loop: pick the oldest PENDING task of a
  // given type whose scheduledAt has passed. status leads so the index can
  // also serve status-filtered lookups.
  @@index([status, type, scheduledAt])
}

model UsageEvent {
  id             String         @id @default(cuid())
  organizationId String
  userId         String?
  type           UsageEventType
  quantity       Int            @default(1)
  unit           String
  subjectType    String?
  subjectId      String?
  metadata       Json?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())

  @@index([organizationId, type, createdAt])
  @@index([userId, createdAt])
}

model DeliveryLog {
  id             String          @id @default(cuid())
  organizationId String
  briefingId     String
  channel        DeliveryChannel @default(TELEGRAM)
  status         DeliveryStatus  @default(PENDING)
  attempt        Int             @default(0)
  recipientRef   String?
  errorMessage   String?
  errorCode      String?
  sentAt         DateTime?
  metadata       Json?
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  briefing       Briefing        @relation(fields: [briefingId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([briefingId, channel])
  @@index([organizationId, status])
  @@index([channel, status])
}

model InstantPushLog {
  id             String            @id @default(cuid())
  organizationId String
  eventId        String
  channel        DeliveryChannel   @default(TELEGRAM)
  status         InstantPushStatus @default(PENDING)
  score          Float
  attempt        Int               @default(0)
  recipientRef   String?
  nextAttemptAt  DateTime?
  lockedAt       DateTime?
  sentAt         DateTime?
  errorMessage   String?
  errorCode      String?
  metadata       Json?
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          IntelligenceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([eventId, channel])
  @@index([organizationId, status, nextAttemptAt])
}

model Report {
  id             String       @id @default(cuid())
  organizationId String
  question       String
  status         ReportStatus @default(PENDING)
  markdown       String?
  summary        String?
  rangeStart     DateTime?
  rangeEnd       DateTime?
  eventCount     Int          @default(0)
  itemCount      Int          @default(0)
  topicIds       String[]     @default([])
  sourceIds      String[]     @default([])
  coverageNote   String?
  generatedAt    DateTime?
  errorMessage   String?
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  refreshToken          String?
  accessToken           String?
  expiresAt             DateTime? // Better Auth accessTokenExpiresAt, mapped via auth.ts account.fields
  refreshTokenExpiresAt DateTime?
  idToken               String?
  scope                 String?
  password              String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([userId, providerId])
  @@index([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Verification {
  id         String   @id @default(cuid())
  value      String
  identifier String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model PaymentInvoice {
  id              String       @id @default(cuid())
  organizationId  String
  plan            Plan
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("USD")
  status          String       @default("PENDING")
  provider        String       @default("ccpayment")
  providerOrderId String?
  invoiceUrl      String?
  periodStart     DateTime?
  periodEnd       DateTime?
  metadata        Json?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([provider, providerOrderId])
  @@index([organizationId, status])
}

model WebhookEvent {
  id             String   @id @default(cuid())
  provider       String
  recordId       String
  organizationId String
  processedAt    DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([provider, recordId])
  @@index([organizationId])
}

enum PlatformAdminRole {
  PLATFORM_OWNER
  PLATFORM_ADMIN
  PLATFORM_AUDITOR
}

enum AuditActorType {
  PLATFORM_ADMIN
  SYSTEM
  USER
}

model PlatformAdmin {
  id           String             @id @default(cuid())
  userId       String             @unique
  role         PlatformAdminRole  @default(PLATFORM_AUDITOR)
  mfaEnabled   Boolean?
  lastReauthAt DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([role])
}

model AuditLog {
  id         String          @id @default(cuid())
  actorType  AuditActorType
  actorId    String
  action     String
  targetType String
  targetId   String
  reason     String?
  before     Json?
  after      Json?
  requestId  String?
  createdAt  DateTime        @default(now())

  @@index([actorType, actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
}
