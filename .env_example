# Database
# Used by Prisma, the Next.js app, and the Node worker.
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public

# AI Provider
# These are fallback credentials. Prefer configuring API keys via the Admin
# backend at /admin/settings. Keys set there take priority over these env vars.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace_with_your_api_key
AI_MODEL_L1=gpt-4o-mini
AI_MODEL_L2=gpt-4o

# Credential encryption
# Required when API keys are configured via the Admin backend (/admin/settings).
# Must be 32 bytes as UTF-8 string or 64 hex characters.
# Generate one with: openssl rand -hex 32
ENCRYPTION_KEY=

# Source discovery
# Brave Search API key is a fallback. Prefer configuring via /admin/settings.
# Without it (and without Admin config), keyword search is skipped and
# backlink/outlink discovery can still run.
BRAVE_SEARCH_API_KEY=replace_with_your_brave_search_key
WANGCHAO_SEARCH_PROVIDER=brave
# Provider type: brave, tavily, serper, searxng
# Tavily API key (if provider=tavily)
# TAVILY_API_KEY=
# Serper API key (if provider=serper)
# SERPER_API_KEY=
# SearXNG base URL (if provider=searxng)
# SEARXNG_BASE_URL=http://localhost:8080
WANGCHAO_DISCOVERY_HIGHSCORE_THRESHOLD=0.7
WANGCHAO_DISCOVERY_LOOKBACK_DAYS=14
WANGCHAO_DISCOVERY_WEEKLY_LIMIT=5
WANGCHAO_DISCOVERY_HIGHSCORE_PAGE_LIMIT=10
WANGCHAO_DISCOVERY_ACTIVE_PAGE_LIMIT=12
WANGCHAO_DISCOVERY_OUTLINKS_PER_PAGE=3
WANGCHAO_DISCOVERY_FETCH_TIMEOUT_MS=5000
WANGCHAO_TOPIC_CREATE_SOURCE_LIMIT=3
WANGCHAO_TOPIC_CREATE_FEED_TIMEOUT_MS=2000

# Default workspace
# Used until a real auth/session provider is introduced.
WANGCHAO_DEFAULT_ORGANIZATION_SLUG=default
WANGCHAO_DEFAULT_ORGANIZATION_NAME=默认工作区
WANGCHAO_DEFAULT_USER_EMAIL=admin@wangchao.local
WANGCHAO_DEFAULT_USER_NAME=管理员

# Seed source list
# Multi-source list (Gist raw URL, or any public JSON).
# Schema: { version:1, topics:[{ name, description?, keywords?, sources:[{name,url}] }] }
# Fetch failures fall back to packages/db/seed-sources.json bundled with the deploy.
# Leave empty to use the default: raw link to this repo's packages/db/seed-sources.json.
WANGCHAO_SEED_SOURCES_URL=

# Local file path override (highest priority).
# Supports both absolute paths and paths relative to the workspace root.
WANGCHAO_SEED_SOURCES_PATH=

# Legacy single-source override: set both to use one RSS source instead of the list.
# Takes priority over WANGCHAO_SEED_SOURCES_URL when both are set.
WANGCHAO_SEED_SOURCE_NAME=
WANGCHAO_SEED_SOURCE_URL=

# Worker fetch concurrency and retry
# Maximum number of RSS sources to fetch concurrently per worker cycle.
WANGCHAO_FETCH_CONCURRENCY=5
# Base delay in milliseconds for exponential backoff between retry attempts.
# Actual delay = FETCH_BACKOFF_BASE_MS * 2^(attempt-1) * jitter(0.5-1.0)
WANGCHAO_FETCH_BACKOFF_BASE_MS=1000
# Total concurrency budget shared across all worker sub-cycles (fetch, article, candidate observation).
WANGCHAO_WORKER_TOTAL_CONCURRENCY=5
# Soft timeout in milliseconds for each worker cycle (default 4 minutes, under Railway's 5-minute limit).
WANGCHAO_WORKER_CYCLE_SOFT_TIMEOUT_MS=240000

# Source governance
# Auto-mute threshold: mute ACTIVE sources after N consecutive failures
# WANGCHAO_AUTO_MUTE_THRESHOLD=10
# Enable candidate source low-frequency observation fetch
# WANGCHAO_CANDIDATE_OBSERVATION_ENABLED=false

# Railway service routing
# Set to `web` for the Next.js service and `worker` for the worker service.
WANGCHAO_RAILWAY_ROLE=web

# Optional Railway predeploy database readiness tuning.
WANGCHAO_DB_WAIT_TIMEOUT_MS=180000
WANGCHAO_DB_WAIT_INTERVAL_MS=2000

# Telegram delivery (optional)
# Telegram Bot Token and Chat ID are configured via /admin/settings and encrypted in DB.
# This env var is only used to override the Telegram API base URL (e.g. for proxies).
# TELEGRAM_API_BASE=https://api.telegram.org
WANGCHAO_INSTANT_PUSH_SCORE_THRESHOLD=90
WANGCHAO_INSTANT_PUSH_MAX_PER_CYCLE=10
WANGCHAO_INSTANT_PUSH_MAX_ATTEMPTS=3

# Semantic dedup
WANGCHAO_SEMANTIC_DEDUP_THRESHOLD=0.7
WANGCHAO_DEDUP_MAX_COMPARISONS=20
WANGCHAO_DEDUP_MAX_CANDIDATES=10

# Better Auth (authentication)
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# The base URL of your deployed app (used for auth callbacks)
BETTER_AUTH_URL=http://localhost:3000

# CCPayment (crypto payment — optional, configure via /admin/settings)
# These are fallback env vars; prefer configuring via Admin backend.
# CCPAYMENT_APP_ID=
# CCPAYMENT_APP_SECRET=

# Stripe (skeleton — not enabled for real payments yet)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PLUS_PRICE_ID=
# STRIPE_PRO_PRICE_ID=
