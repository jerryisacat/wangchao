# AI Provider Configuration
# Compatible with OpenAI, DeepSeek, generic OpenAI-compatible APIs
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_api_key_here

# Model Selection
# L1: Fast/Cheap model for initial screening (e.g., gpt-4o-mini, deepseek-chat)
AI_MODEL_L1=gpt-4o-mini
# L2: Smarter model for scoring and summarization (e.g., gpt-4o, deepseek-reasoner)
AI_MODEL_L2=gpt-4o

# Batch Processing Settings
# Increase these to handle higher news volume, decrease if hitting rate limits
# Hard caps for how many batches one cycle may process before sleeping again
MAX_L1_LOOPS=5
MAX_L2_LOOPS=5
# How many news items to send to AI in one L1 batch
L1_BATCH_SIZE=30
# How many high-score items to send to L2 scoring in one batch
L2_BATCH_SIZE=20

# Database path. Parent directory is created automatically.
DB_PATH=data/news.db

# Ranking Settings
# Time decay factor. 1.8=Strong decay (Freshness), 0.8=Weak decay (Absolute Hotness)
GRAVITY=1.1
# How many hours of news to include in the ranking list
RANKING_WINDOW_HOURS=72

# Output Settings
# How many items to generate in top5.json
TOP_N_ITEMS=5

# Quiet Hours (reduce update frequency during nighttime to save API costs)
# Set to false to disable
QUIET_HOURS_ENABLED=true
# Timezone offset from UTC (e.g., 8 for UTC+8)
QUIET_HOURS_TZ_OFFSET=8
# Start hour (inclusive) and end hour (exclusive) in the configured timezone
QUIET_HOURS_START=22
QUIET_HOURS_END=10
# Interval multiplier during quiet hours (4 = update 4x less frequently)
QUIET_HOURS_MULTIPLIER=4

# Proxy Settings (Optional)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# RSS Feeds (JSON Array)
RSS_FEEDS=["https://spaceflightnow.com/feed/", "https://hnrss.org/newest?points=100"]

